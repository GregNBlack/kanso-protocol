{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@kanso-protocol/core": ["packages/core/src/index.ts"],
      "@kanso-protocol/button": ["packages/components/button/src/index.ts"],
      "@kanso-protocol/input": ["packages/components/input/src/index.ts"],
      "@kanso-protocol/checkbox": ["packages/components/checkbox/src/index.ts"],
      "@kanso-protocol/radio": ["packages/components/radio/src/index.ts"],
      "@kanso-protocol/toggle": ["packages/components/toggle/src/index.ts"],
      "@kanso-protocol/form-field": ["packages/components/form-field/src/index.ts"],
      "@kanso-protocol/menu": ["packages/components/menu/src/index.ts"],
      "@kanso-protocol/textarea": ["packages/components/textarea/src/index.ts"],
      "@kanso-protocol/select": ["packages/components/select/src/index.ts"],
      "@kanso-protocol/number-stepper": ["packages/components/number-stepper/src/index.ts"],
      "@kanso-protocol/segmented-control": ["packages/components/segmented-control/src/index.ts"],
      "@kanso-protocol/badge": ["packages/components/badge/src/index.ts"],
      "@kanso-protocol/alert": ["packages/components/alert/src/index.ts"],
      "@kanso-protocol/tooltip": ["packages/components/tooltip/src/index.ts"],
      "@kanso-protocol/popover": ["packages/components/popover/src/index.ts"],
      "@kanso-protocol/progress": ["packages/components/progress/src/index.ts"],
      "@kanso-protocol/tabs": ["packages/components/tabs/src/index.ts"],
      "@kanso-protocol/breadcrumbs": ["packages/components/breadcrumbs/src/index.ts"],
      "@kanso-protocol/pagination": ["packages/components/pagination/src/index.ts"],
      "@kanso-protocol/dialog": ["packages/components/dialog/src/index.ts"],
      "@kanso-protocol/divider": ["packages/components/divider/src/index.ts"],
      "@kanso-protocol/card": ["packages/components/card/src/index.ts"],
      "@kanso-protocol/empty-state": ["packages/components/empty-state/src/index.ts"],
      "@kanso-protocol/drawer": ["packages/components/drawer/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
