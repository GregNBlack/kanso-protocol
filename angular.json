{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "kanso-protocol": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "packages",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist",
            "browser": "packages/core/src/index.ts",
            "tsConfig": ".storybook/tsconfig.json"
          }
        }
      }
    }
  }
}
