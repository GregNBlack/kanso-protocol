{
  "name": "@kanso-protocol/elements",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Framework-agnostic custom elements for the Kanso Protocol design system — use <kp-*> components from React, Vue, Svelte, or plain HTML, no Angular required.",
  "author": "GregNBlack",
  "type": "module",
  "module": "./kanso-elements.mjs",
  "customElements": "custom-elements.json",
  "exports": {
    ".": {
      "types": "./kanso-elements.d.ts",
      "default": "./kanso-elements.mjs"
    },
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "kanso-elements.mjs",
    "kanso-elements.mjs.map",
    "kanso-elements.d.ts",
    "custom-elements.json",
    "README.md"
  ],
  "sideEffects": [
    "./kanso-elements.mjs"
  ],
  "keywords": [
    "design-system",
    "web-components",
    "custom-elements",
    "react",
    "vue",
    "ui-components",
    "kanso"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GregNBlack/kanso-protocol.git",
    "directory": "packages/elements"
  },
  "publishConfig": {
    "access": "public"
  }
}
