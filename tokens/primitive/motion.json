{
  "motion": {
    "duration": {
      "$type": "duration",
      "fast":   { "$value": "120ms" },
      "normal": { "$value": "200ms" },
      "slow":   { "$value": "300ms" }
    },
    "ease": {
      "$type": "cubicBezier",
      "in":     { "$value": [0.4, 0, 1, 1] },
      "out":    { "$value": [0, 0, 0.2, 1] },
      "in-out": { "$value": [0.4, 0, 0.2, 1] }
    }
  }
}
