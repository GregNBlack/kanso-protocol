{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans":  { "$value": ["Onest", "system-ui", "sans-serif"], "$description": "Primary UI font" },
      "mono":  { "$value": ["SF Mono", "Monaco", "Consolas", "monospace"], "$description": "Monospace for code" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400, "$description": "Body text" },
      "medium":   { "$value": 500, "$description": "Emphasis, small text, section labels" },
      "semibold": { "$value": 600, "$description": "Headings" },
      "bold":     { "$value": 700, "$description": "Strong emphasis" }
    },
    "size": {
      "$type": "dimension",
      "2xs": { "$value": "11px", "$description": "Micro labels, captions" },
      "xs":  { "$value": "12px", "$description": "Small body, hints" },
      "sm":  { "$value": "14px", "$description": "Default body text, UI" },
      "md":  { "$value": "16px", "$description": "Comfortable body, large UI" },
      "lg":  { "$value": "20px", "$description": "Section labels, small headings" },
      "xl":  { "$value": "24px", "$description": "Headings" },
      "2xl": { "$value": "32px", "$description": "Large headings, hero text" }
    },
    "lineHeight": {
      "$type": "dimension",
      "2xs": { "$value": "16px", "$description": "Pairs with size 2xs (11px) — 4px grid" },
      "xs":  { "$value": "16px", "$description": "Pairs with size xs (12px)" },
      "sm":  { "$value": "20px", "$description": "Pairs with size sm (14px)" },
      "md":  { "$value": "24px", "$description": "Pairs with size md (16px)" },
      "lg":  { "$value": "28px", "$description": "Pairs with size lg (20px)" },
      "xl":  { "$value": "32px", "$description": "Pairs with size xl (24px)" },
      "2xl": { "$value": "40px", "$description": "Pairs with size 2xl (32px)" }
    }
  }
}
