{
  "elevation": {
    "$type": "shadow",
    "none": {
      "$value": [
        { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px", "color": "rgba(0,0,0,0)" }
      ]
    },
    "raised": {
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(9,9,11,0.08)" },
        { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "-1px", "color": "rgba(9,9,11,0.05)" },
        { "offsetX": "0px", "offsetY": "0px", "blur": "4px", "spread": "-1px", "color": "rgba(9,9,11,0.03)" }
      ]
    },
    "overlay": {
      "$value": [
        { "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-2px", "color": "rgba(9,9,11,0.10)" },
        { "offsetX": "0px", "offsetY": "2px", "blur": "10px", "spread": "-2px", "color": "rgba(9,9,11,0.06)" },
        { "offsetX": "0px", "offsetY": "0px", "blur": "16px", "spread": "-4px", "color": "rgba(9,9,11,0.04)" }
      ]
    },
    "floating": {
      "$value": [
        { "offsetX": "0px", "offsetY": "8px", "blur": "16px", "spread": "-4px", "color": "rgba(9,9,11,0.12)" },
        { "offsetX": "0px", "offsetY": "4px", "blur": "24px", "spread": "-4px", "color": "rgba(9,9,11,0.08)" },
        { "offsetX": "0px", "offsetY": "0px", "blur": "40px", "spread": "-8px", "color": "rgba(9,9,11,0.05)" }
      ]
    }
  }
}
