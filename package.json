    "@angular/platform-browser-dynamic": "^18.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@chromatic-com/storybook": "^3.2.7",
    "@compodoc/compodoc": "^1.1.25",
    "@nx/angular": "^19.8.0",
